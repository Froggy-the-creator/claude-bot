# Copy this file to .env and fill in your own values.
# .env is gitignored and must never be committed.

# Required - authenticates calls to the Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required - used to verify that incoming webhooks really came from Twilio.
# Found in the Twilio console under Account Info.
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Optional - numbers permitted to run the !all admin command.
# Comma-separated, in the format Twilio sends (note the whatsapp: prefix).
ADMIN_NUMBERS=whatsapp:+6500000000
